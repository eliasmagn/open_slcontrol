#!/bin/sh /etc/rc.common
USE_PROCD=1
START=95
STOP=10

start_service() {
  . /lib/functions.sh
  config_load heizungpanel

  local can_if can_bitrate can_setup listen_only
  local mqtt_host mqtt_port mqtt_base

  config_get can_if      main can_if      "can0"
  config_get can_bitrate main can_bitrate "69144"
  config_get can_setup   main can_setup   "1"
  config_get listen_only main listen_only "1"

  config_get mqtt_host   main mqtt_host   "127.0.0.1"
  config_get mqtt_port   main mqtt_port   "1883"
  config_get mqtt_base   main mqtt_base   "heizungpanel"

  local topic_raw="${mqtt_base}/raw"
  local topic_state="${mqtt_base}/state"

  if [ "$can_setup" = "1" ]; then
    local lo_arg=""
    [ "$listen_only" = "1" ] && lo_arg="listen-only on" || lo_arg=""
    ip link set "$can_if" down >/dev/null 2>&1 || true
    ip link set "$can_if" type can bitrate "$can_bitrate" $lo_arg >/dev/null 2>&1 || true
    ip link set "$can_if" up >/dev/null 2>&1 || true
    logger -t heizungpanel "CAN setup ok: $can_if bitrate $can_bitrate ${lo_arg:+($lo_arg)}"
  fi

  # RAW bridge: candump -> MQTT raw (line mode)
  procd_open_instance raw
  procd_set_param command /bin/sh -c "candump -L $can_if 2>/dev/null | mosquitto_pub -h $mqtt_host -p $mqtt_port -t $topic_raw -l"
  procd_set_param respawn 3600 5 5
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance

  # STATE bridge: candump -> ucode parser -> MQTT retained state
  procd_open_instance state
  procd_set_param env CAN_IF="$can_if" CAN_BITRATE="$can_bitrate"
  procd_set_param command /bin/sh -c "candump -L $can_if 2>/dev/null | /usr/bin/ucode /usr/libexec/heizungpanel/parser.uc | mosquitto_pub -h $mqtt_host -p $mqtt_port -t $topic_state -r -l"
  procd_set_param respawn 3600 5 5
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance

  logger -t heizungpanel "MQTT publishing: raw=$topic_raw state=$topic_state (retained)"
}

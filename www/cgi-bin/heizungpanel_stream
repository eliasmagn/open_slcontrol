#!/bin/sh

TOKEN_EXPECTED="$(uci -q get heizungpanel.main.stream_token)"
MQTT_HOST="$(uci -q get heizungpanel.main.mqtt_host)"
MQTT_PORT="$(uci -q get heizungpanel.main.mqtt_port)"
MQTT_BASE="$(uci -q get heizungpanel.main.mqtt_base)"

[ -n "$MQTT_HOST" ] || MQTT_HOST="127.0.0.1"
[ -n "$MQTT_PORT" ] || MQTT_PORT="1883"
[ -n "$MQTT_BASE" ] || MQTT_BASE="heizungpanel"

TOPIC_RAW="${MQTT_BASE}/raw"
TOPIC_STATE="${MQTT_BASE}/state"
TOPIC_MODE_DURABLE="${MQTT_BASE}/mode"
TOPIC_MODE_CURRENT="${TOPIC_MODE_DURABLE}/current"
TOPIC_SNAPSHOT="${MQTT_BASE}/snapshot"
TOPIC_BOOTSTRAP="${MQTT_BASE}/bootstrap"

qs_get() {
  local key="$1"
  local in="${QUERY_STRING:-}"
  local part k v
  local oldifs="$IFS"
  IFS='&'
  for part in $in; do
    k="${part%%=*}"
    v="${part#*=}"
    [ "$k" = "$key" ] || continue
    IFS="$oldifs"
    printf '%s' "$v"
    return 0
  done
  IFS="$oldifs"
  return 1
}

TOKEN_GIVEN="$(qs_get token)"
if [ -n "$TOKEN_EXPECTED" ] && [ "$TOKEN_GIVEN" != "$TOKEN_EXPECTED" ]; then
  echo "Status: 403 Forbidden"
  echo "Content-Type: text/plain"
  echo
  echo "forbidden"
  exit 0
fi

MODE="$(qs_get mode)"
case "$MODE" in
  ''|raw) TOPIC="$TOPIC_RAW" ;;
  state) TOPIC="$TOPIC_STATE" ;;
  mode|mode_durable) TOPIC="$TOPIC_MODE_DURABLE" ;;
  mode_current|current|mode/current) TOPIC="$TOPIC_MODE_CURRENT" ;;
  snapshot) TOPIC="$TOPIC_SNAPSHOT" ;;
  bootstrap) TOPIC="$TOPIC_BOOTSTRAP" ;;
  *) TOPIC="$TOPIC_RAW" ;;
esac

echo "Content-Type: text/event-stream"
echo "Cache-Control: no-cache"
echo "Connection: keep-alive"
echo

echo "event: hello"
echo "data: stream-open"
echo

exec mosquitto_sub -h "$MQTT_HOST" -p "$MQTT_PORT" -t "$TOPIC" 2>/dev/null \
  | while IFS= read -r line; do
      [ -n "$line" ] || continue
      printf 'data: %s\n\n' "$line"
    done

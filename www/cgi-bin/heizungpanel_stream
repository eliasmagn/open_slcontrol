#!/bin/sh

TOKEN_EXPECTED="$(uci -q get heizungpanel.main.stream_token)"
MQTT_HOST="$(uci -q get heizungpanel.main.mqtt_host)"
MQTT_PORT="$(uci -q get heizungpanel.main.mqtt_port)"
MQTT_BASE="$(uci -q get heizungpanel.main.mqtt_base)"

[ -n "$MQTT_HOST" ] || MQTT_HOST="127.0.0.1"
[ -n "$MQTT_PORT" ] || MQTT_PORT="1883"
[ -n "$MQTT_BASE" ] || MQTT_BASE="heizungpanel"

TOPIC_RAW="${MQTT_BASE}/raw"
TOPIC_STATE="${MQTT_BASE}/state"

SUB_PID=""
FIFO_PATH=""

cleanup() {
  [ -n "$SUB_PID" ] && kill "$SUB_PID" >/dev/null 2>&1 || true
  [ -n "$FIFO_PATH" ] && rm -f "$FIFO_PATH" >/dev/null 2>&1 || true
}

trap cleanup EXIT INT TERM PIPE HUP

qs_get() {
  local key="$1"
  local in="${QUERY_STRING:-}"
  local part k v
  local oldifs="$IFS"
  IFS='&'
  for part in $in; do
    k="${part%%=*}"
    v="${part#*=}"
    [ "$k" = "$key" ] || continue
    IFS="$oldifs"
    printf '%s' "$v"
    return 0
  done
  IFS="$oldifs"
  return 1
}

TOKEN_GIVEN="$(qs_get token)"
if [ -n "$TOKEN_EXPECTED" ] && [ "$TOKEN_GIVEN" != "$TOKEN_EXPECTED" ]; then
  echo "Status: 403 Forbidden"
  echo "Content-Type: text/plain"
  echo
  echo "forbidden"
  exit 0
fi

MODE="$(qs_get mode)"
case "$MODE" in
  ''|raw) TOPIC="$TOPIC_RAW" ;;
  state) TOPIC="$TOPIC_STATE" ;;
  bootstrap) TOPIC="__bootstrap_on_demand__" ;;
  *) TOPIC="$TOPIC_RAW" ;;
esac

echo "Content-Type: text/event-stream"
echo "Cache-Control: no-cache"
echo "Connection: keep-alive"
echo

echo "event: hello"
echo "data: stream-open"
echo

if [ "$TOPIC" = "__bootstrap_on_demand__" ]; then
  BOOTSTRAP_JSON="$(/usr/libexec/heizungpanel/state.sh 2>/dev/null)"
  [ -n "$BOOTSTRAP_JSON" ] && printf 'data: %s\n\n' "$BOOTSTRAP_JSON"
  exit 0
fi

FIFO_PATH="/tmp/heizungpanel_stream.$$.$RANDOM.fifo"
mkfifo "$FIFO_PATH" || exit 1

mosquitto_sub -h "$MQTT_HOST" -p "$MQTT_PORT" -t "$TOPIC" 2>/dev/null > "$FIFO_PATH" &
SUB_PID="$!"

while true; do
  if IFS= read -r -t 15 line < "$FIFO_PATH"; then
    [ -n "$line" ] || continue
    printf 'data: %s\n\n' "$line" || break
  else
    printf ': ping\n\n' || break
  fi
done

exit 0
